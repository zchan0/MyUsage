---
/**
 * SVG depiction of three Macs writing to / reading from a shared
 * sync folder. Solid arrows = "writes own subfolder";
 * dashed = "reads peer subfolders".
 */
---

<div class="sync-diagram">
  <svg viewBox="0 0 600 280" width="100%" style="max-width:560px; margin: 0 auto; display:block;" aria-label="Three Macs writing per-device snapshots to a shared folder">
    <defs>
      <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
        <path d="M0,0 L10,5 L0,10 Z" fill="hsl(145 33% 32%)" />
      </marker>
    </defs>

    <!-- Three Macs -->
    <g font-family="ui-monospace,Menlo" font-size="11" fill="hsl(220 6% 38%)" text-anchor="middle">
      <g transform="translate(80, 60)">
        <rect x="0" y="0" width="80" height="50" rx="4" fill="none" stroke="currentColor" stroke-width="1"/>
        <rect x="0" y="50" width="80" height="3" fill="currentColor"/>
        <rect x="35" y="53" width="10" height="2" fill="currentColor"/>
        <text x="40" y="74" font-size="10">Mac · Air</text>
      </g>
      <g transform="translate(260, 30)">
        <rect x="0" y="0" width="80" height="50" rx="4" fill="none" stroke="currentColor" stroke-width="1"/>
        <rect x="0" y="50" width="80" height="3" fill="currentColor"/>
        <rect x="35" y="53" width="10" height="2" fill="currentColor"/>
        <text x="40" y="74" font-size="10">Mac · Studio</text>
      </g>
      <g transform="translate(440, 60)">
        <rect x="0" y="0" width="80" height="50" rx="4" fill="none" stroke="currentColor" stroke-width="1"/>
        <rect x="0" y="50" width="80" height="3" fill="currentColor"/>
        <rect x="35" y="53" width="10" height="2" fill="currentColor"/>
        <text x="40" y="74" font-size="10">Mac · mini</text>
      </g>
    </g>

    <!-- Sync folder -->
    <g transform="translate(220, 165)">
      <rect x="0" y="0" width="160" height="80" rx="6" fill="hsl(145 25% 95%)" stroke="hsl(145 33% 32%)" stroke-width="1"/>
      <text x="80" y="20" font-family="ui-monospace,Menlo" font-size="10" fill="hsl(145 33% 32%)" text-anchor="middle" letter-spacing="0.06em">SYNC FOLDER</text>
      <line x1="20" y1="28" x2="140" y2="28" stroke="hsl(145 22% 80%)" stroke-width="0.5"/>
      <text x="80" y="46" font-family="ui-monospace,Menlo" font-size="9.5" fill="hsl(220 6% 38%)" text-anchor="middle">devices/7F3C…/</text>
      <text x="80" y="60" font-family="ui-monospace,Menlo" font-size="9.5" fill="hsl(220 6% 38%)" text-anchor="middle">devices/4E91…/</text>
      <text x="80" y="74" font-family="ui-monospace,Menlo" font-size="9.5" fill="hsl(220 6% 38%)" text-anchor="middle">devices/B8D7…/</text>
    </g>

    <g stroke="hsl(145 33% 32%)" stroke-width="1.2" fill="none" marker-end="url(#arrow)">
      <path d="M 120 115 Q 170 165 240 168" />
      <path d="M 300 85 Q 300 130 300 162" />
      <path d="M 480 115 Q 430 165 360 168" />
    </g>
    <g stroke="hsl(220 6% 58%)" stroke-width="0.8" fill="none" stroke-dasharray="3 3">
      <path d="M 240 200 Q 170 215 130 130" />
      <path d="M 300 230 Q 300 200 300 90" />
      <path d="M 360 200 Q 430 215 470 130" />
    </g>

    <g font-family="ui-monospace,Menlo" font-size="9" fill="hsl(220 6% 58%)">
      <line x1="35" y1="260" x2="55" y2="260" stroke="hsl(145 33% 32%)" stroke-width="1.2" marker-end="url(#arrow)"/>
      <text x="62" y="263">writes own subfolder</text>
      <line x1="220" y1="260" x2="240" y2="260" stroke="hsl(220 6% 58%)" stroke-width="0.8" stroke-dasharray="3 3"/>
      <text x="247" y="263">reads peer subfolders</text>
    </g>
  </svg>
</div>
