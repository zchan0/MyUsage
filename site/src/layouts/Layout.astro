---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  /** Path to the page's `.md` source under `/`, e.g. `/docs/claude.md`.
      When set, emits `<link rel="alternate" type="text/markdown">` so
      retrieval crawlers (Claude Code, Cursor) can grab clean Markdown. */
  markdownAlternate?: string;
  /** OG image override (defaults to /og.png). */
  ogImage?: string;
}

const { title, description, markdownAlternate, ogImage = '/og.png' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- OpenGraph / Twitter -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {markdownAlternate && (
      <link rel="alternate" type="text/markdown" href={markdownAlternate} />
    )}

    <!-- Search engine verification -->
    <meta name="google-site-verification" content="ws58BEuoSlHHHNKzx9IgmsrepdABsoaRaWVw_MsfEs4" />
    <meta name="msvalidate.01" content="4142C0E7DBB83A345622E7344D41C8D4" />

    <link rel="icon" type="image/png" href={`${base}/icons/app-icon.png`} />
    <link rel="apple-touch-icon" href={`${base}/icons/app-icon-256.png`} />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <header class="site-header">
      <a href={base || '/'} class="brand">
        <img class="brand-mark-img" src={`${base}/icons/app-icon.png`} alt="MyUsage app icon" width="28" height="28" />
        <span class="brand-name">MyUsage</span>
      </a>
      <nav class="site-nav">
        <a href={`${base}/install`}>Install</a>
        <a href={`${base}/docs/multi-device-sync`}>Docs</a>
        <a href={`${base}/blog`}>Blog</a>
        <a class="ext" href="https://github.com/zchan0/MyUsage" rel="external">GitHub ↗</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <span>MyUsage · MIT</span>
      <span>
        <a href="https://github.com/zchan0/MyUsage">Source</a> &middot;
        <a href="https://github.com/zchan0/MyUsage/blob/main/CHANGELOG.md">Changelog</a> &middot;
        <a href={`${base}/blog`}>Blog</a>
      </span>
    </footer>
  </body>
</html>
