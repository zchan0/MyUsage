---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const dateFmt = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'short', day: 'numeric' });
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Blog — MyUsage"
  description="Development stories, design iteration journals, and architecture notes from building MyUsage."
>
  <article class="reading">
    <span class="meta-row">§ Blog</span>
    <h1>Notes from building MyUsage.</h1>
    <p class="post-lede">Architecture decisions, design iterations, and the occasional yak-shave from the engineering side of a small macOS utility.</p>

    {posts.length > 0 ? (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <h3>
              <a href={`${base}/blog/${post.slug}`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()}>
              {dateFmt.format(post.data.pubDate)}
            </time>
          </li>
        ))}
      </ul>
    ) : (
      <div class="callout">
        <div>
          <strong>Coming soon.</strong> First posts on the way.
        </div>
      </div>
    )}
  </article>
</Layout>
