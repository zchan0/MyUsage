---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const dateFmt = new Intl.DateTimeFormat('en', { year: 'numeric', month: 'short', day: 'numeric' });
---

<Layout
  title="Blog — MyUsage"
  description="Development stories, design iteration journals, and architecture notes from building MyUsage."
>
  <h1>Blog</h1>
  <p>
    Notes from building MyUsage — design iterations, architecture decisions,
    and the occasional yak-shave. Topics in flight:
  </p>

  {posts.length > 0 ? (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <h3>
            <a href={`${import.meta.env.BASE_URL}/blog/${post.slug}`}>{post.data.title}</a>
          </h3>
          <p>{post.data.description}</p>
          <time datetime={post.data.pubDate.toISOString()}>
            {dateFmt.format(post.data.pubDate)}
          </time>
        </li>
      ))}
    </ul>
  ) : (
    <div class="callout">
      <b>Coming soon.</b> The first two posts on the way:
      <ul>
        <li>Designing a 4 pt progress bar — eight iterations with Claude Code as designer-of-record</li>
        <li>No backend, BYO sync folder — multi-device aggregation without a server</li>
      </ul>
    </div>
  )}
</Layout>
